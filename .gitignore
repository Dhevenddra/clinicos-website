# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# safety: never commit memory, session logs, or personal notes to a public repo
MEMORY.md
memory/
.claude/
.claude-*/
session-*.md
SESSION_*.md
NOTES.md
TODO.md
PERSONAL.md
*.secret
*.secrets
secrets.json
credentials.json

# safety: never commit demo screenshots or clinic data dumps
/clinicos-website-assets/
/public/shots/raw/
*.sql.dump
